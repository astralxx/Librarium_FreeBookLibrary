# Auth Service Configuration (PostgreSQL)
DB_USER=postgres
DB_PASS=ur_password
DB_HOST=localhost
DB_PORT=5432
DB_NAME=librariumdb

# JWT — 34 символа (специально сделал длиннее, чтобы не было проблем)
JWT_SECRET=SuperSecretJWTKeyForLibrarium2026!@#$

# Yandex OAuth 
YANDEX_CLIENT_ID=your_yandex_client_id_here
YANDEX_CLIENT_SECRET=your_yandex_client_secret_here
YANDEX_REDIRECT_URL=http://localhost:3000/auth/yandex/callback

# Server
SERVER_HOST=127.0.0.1
SERVER_PORT=3000

# Frontend
FRONTEND_URL=http://localhost:5173

# Cookie
COOKIE_SECURE=false
COOKIE_SAMESITE=Lax